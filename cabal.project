packages:
  effectful-core/*.cabal
  effectful-plugin/*.cabal
  effectful-th/*.cabal
  effectful/*.cabal

-- Ignore dependency bounds of other effect libraries.
allow-newer: cleff:*
           , freer-simple:*
           , fused-effects:*
           , polysemy:*

-- strict-mutable-base 2.0.0.0
source-repository-package
    type: git
    location: https://github.com/arybczak/strict-mutable.git
    tag: a60db945dcc3283da2c5d45dadf423fadc2ff745
    subdir: strict-mutable-base
